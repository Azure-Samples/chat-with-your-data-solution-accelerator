# CWYD v2 local dev environment template.
#
# Copy to v2/.env (gitignored) and fill in values for any external services you
# want to hit. Every variable name below matches the canonical AppSettings field
# in v2/src/backend/core/settings.py and the corresponding Bicep output in
# v2/infra/main.bicep -- no v1 aliases. Pydantic-settings ignores unknown
# variables, so a typo here silently does nothing; double-check spelling.
#
# Single source of truth at v2/ root (CU-008a, 2026-05-05). The previous
# v2/docker/.env.dev.example file was deleted; do not recreate it.
#
# Defaults: docker-compose.dev.yml hard-codes the local stack (azurite + a
# pgvector-enabled postgres container) by overriding AZURE_DB_TYPE,
# AZURE_INDEX_STORE, AZURE_POSTGRES_ENDPOINT, AZURE_STORAGE_BLOB_URL, and
# AZURE_STORAGE_QUEUE_URL on the backend service. Setting those four here has
# no effect on the default profile -- only matters if you override compose.

# --- Azure AI / Foundry IQ (required for real LLM calls; mocked otherwise) ---
# FoundrySettings.services_endpoint -- host of the unified AI Services account
# (kind=AIServices). Drives the Document Intelligence ingestion parser
# (Functions batch_push) and the Foundry IQ embeddings client. MUST be a
# non-empty https:// URL or PDF/DOCX ingestion fails fast with an actionable
# error (BUG-0034). Bicep output: AZURE_AI_SERVICES_ENDPOINT in v2/infra/main.bicep.
AZURE_AI_SERVICES_ENDPOINT=
# FoundrySettings.project_endpoint -- Agent Framework + LangGraph both use this.
AZURE_AI_PROJECT_ENDPOINT=
# OpenAISettings.* -- model deployment names exposed via the Foundry account.
AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5.1
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure AI Search (cosmosdb-mode only; ignored in pgvector dev default) ---
# SearchSettings.endpoint -- full https URL of the search service.
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX=cwyd-index
# SearchSettings.knowledge_base_* -- Foundry IQ Knowledge Base over the index
# (grounds the agent_framework orchestrator). The KB REST API version is pinned
# here so it can be bumped without a code change.
AZURE_AI_SEARCH_KNOWLEDGE_BASE_NAME=cwyd-kb
AZURE_AI_SEARCH_KNOWLEDGE_SOURCE_NAME=cwyd-index-ks
AZURE_AI_SEARCH_KNOWLEDGE_BASE_API_VERSION=2025-11-01-preview

# --- Identity (optional locally; uses AzureCliCredential when unset) ---
# IdentitySettings.* -- AppSettings reads AZURE_TENANT_ID + AZURE_UAMI_CLIENT_ID.
AZURE_TENANT_ID=
AZURE_UAMI_CLIENT_ID=

# --- Orchestrator selection (runtime-tunable; CWYD_ namespace by design) ---
# OrchestratorSettings.name -- "langgraph" or "agent_framework". Both
# orchestrators ground on either index store and are switchable from the admin
# UI without a redeploy. On pgvector (AZURE_DB_TYPE=postgresql) both run
# app-side RAG over the pgvector index; on Azure AI Search (cosmosdb mode)
# agent_framework additionally grounds on a Foundry IQ Knowledge Base over that
# index, while langgraph runs client-side RAG. ADR 0027 supersedes the ADR 0022
# pgvector + agent_framework block, so neither pairing is rejected. The local
# dev compose default database is pgvector.
CWYD_ORCHESTRATOR_NAME=agent_framework
#
# Foundry agent identity is NOT configured here (CU-009, ADR 0008).
# Agents are bootstrapped lazily on first request and cached in the
# application database (Cosmos in cosmosdb mode, Postgres in postgresql
# mode). To force re-creation, delete the row in the `agents` table.
# See v2/docs/agents.md for details.

# --- Observability ---
# ObservabilitySettings.log_level -- AppSettings env_prefix is AZURE_, so the
# var name is AZURE_LOG_LEVEL (bare LOG_LEVEL in v1 is silently ignored).
AZURE_LOG_LEVEL=INFO
# ObservabilitySettings.app_insights_connection_string -- when set,
# azure-monitor-opentelemetry exports directly to App Insights. AppSettings
# reads the AZURE_-prefixed name (env_prefix=AZURE_); the legacy bare
# `APPLICATIONINSIGHTS_CONNECTION_STRING` is intentionally not honored
# post-CU-002b -- use the typed name only.
AZURE_APP_INSIGHTS_CONNECTION_STRING=

# --- Backend HTTP (CORS, etc.) ---
# Comma-separated list of allowed origins for the FastAPI CORSMiddleware.
# Wired into NetworkSettings.cors_origins via CU-002.
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- Speech-to-text (S1 / SPEECH-MVP, optional) ---
# Populate to enable the `/api/speech` route used by the browser
# microphone button. Empty -> route returns 503 (feature disabled).
# AAD-only: the workload identity (UAMI in production, AzureCli /
# DefaultAzureCredential locally) must hold `Cognitive Services Speech
# User` on the Speech account. NO subscription key (Hard Rule #2).
AZURE_SPEECH_SERVICE_NAME=
AZURE_SPEECH_SERVICE_REGION=
# Full ARM resource id of the Speech account; goes in the
# `x-ms-cognitiveservices-resource-id` header during AAD token mint.
AZURE_SPEECH_ACCOUNT_RESOURCE_ID=
# Comma-separated BCP-47 language tags the recognizer auto-detects.
AZURE_SPEECH_RECOGNIZER_LANGUAGES=en-US,fr-FR,de-DE,it-IT

# --- Content Safety (PARITY-IMPL, optional) ---
# Wires the prompt-shielding guard the chat pipeline runs before every
# Foundry IQ call (`ContentSafetyGuard.screen()` posts to the
# `AnalyzeText` REST endpoint). Empty endpoint -> lifespan leaves
# `app.state.content_safety_client = None` and `get_content_safety_guard`
# returns None so the pipeline runs unguarded (mirrors v1
# `enable_content_safety: false` default).
# AAD-only: the workload identity must hold `Cognitive Services User`
# (a97b65f3-24c7-4388-baec-2e87135dc908) on the account. NO
# subscription key (Hard Rule #2).
AZURE_CONTENT_SAFETY_ENDPOINT=
# Defaults to true (secure-by-default). Both `enabled=true` AND a
# non-empty endpoint are required to construct the client at lifespan
# start, so this stays inert until AZURE_CONTENT_SAFETY_ENDPOINT is
# set above. Operators flip the guard OFF per-request via
# `PATCH /api/admin/config {"content_safety_enabled": false}`
# (`RuntimeConfig` override; `false` short-circuits to None even when
# the lifespan client is present).
AZURE_CONTENT_SAFETY_ENABLED=true
# Inclusive lower bound at which Content Safety verdicts trip. Azure
# reports severity 0/2/4/6 (0=safe, 2=low, 4=medium, 6=high); default
# 4 matches v1's `enable_content_safety: true` behavior. Range 0-7.
AZURE_CONTENT_SAFETY_SEVERITY_THRESHOLD=4

# --- Frontend (consumed by the frontend container build) ---
VITE_BACKEND_URL=http://localhost:8000
