{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "deploymentFlavor": {
      "value": "${DEPLOYMENT_FLAVOR=avm}"
    },
    "solutionName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "azureAiServiceLocation": {
      "value": "${AZURE_AI_SERVICE_LOCATION}"
    },
    "databaseType": {
      "value": "${DATABASE_TYPE=postgresql}"
    },
    "gptModelName": {
      "value": "${AZURE_GPT_MODEL_NAME=gpt-5.1}"
    },
    "gptModelVersion": {
      "value": "${AZURE_GPT_MODEL_VERSION=2025-11-13}"
    },
    "gptModelDeploymentType": {
      "value": "${AZURE_GPT_MODEL_DEPLOYMENT_TYPE=GlobalStandard}"
    },
    "gptModelCapacity": {
      "value": "${AZURE_GPT_MODEL_CAPACITY=150}"
    },
    "reasoningModelName": {
      "value": "${AZURE_REASONING_MODEL_NAME=o4-mini}"
    },
    "reasoningModelVersion": {
      "value": "${AZURE_REASONING_MODEL_VERSION=2025-04-16}"
    },
    "reasoningModelDeploymentType": {
      "value": "${AZURE_REASONING_MODEL_DEPLOYMENT_TYPE=GlobalStandard}"
    },
    "reasoningModelCapacity": {
      "value": "${AZURE_REASONING_MODEL_CAPACITY=50}"
    },
    "embeddingModelName": {
      "value": "${AZURE_EMBEDDING_MODEL_NAME=text-embedding-3-large}"
    },
    "embeddingModelVersion": {
      "value": "${AZURE_EMBEDDING_MODEL_VERSION=1}"
    },
    "embeddingModelDeploymentType": {
      "value": "${AZURE_EMBEDDING_MODEL_DEPLOYMENT_TYPE=Standard}"
    },
    "embeddingModelCapacity": {
      "value": "${AZURE_EMBEDDING_MODEL_CAPACITY=100}"
    },
    "azureOpenAiApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION=2025-01-01-preview}"
    },
    "azureAiAgentApiVersion": {
      "value": "${AZURE_AI_AGENT_API_VERSION=2025-05-01}"
    },
    "containerRegistryEndpoint": {
      "value": "${AZURE_CONTAINER_REGISTRY_ENDPOINT=testapreg.azurecr.io}"
    },
    "imageTag": {
      "value": "${AZURE_IMAGE_TAG=cwyd}"
    },
    "hostingModel": {
      "value": "${AZURE_APP_SERVICE_HOSTING_MODEL=container}"
    },
    "existingLogAnalyticsWorkspaceId": {
      "value": "${AZURE_ENV_LOG_ANALYTICS_WORKSPACE_ID}"
    }
  }
}
