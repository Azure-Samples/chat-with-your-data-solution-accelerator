# CI validation image — runs Bicep build, what-if preview, pytest, frontend tests, lints.
# Pillar: Stable Core
# Phase: 1
#
# Build: docker build -f v2/docker/Dockerfile.ci-validate -t cwyd-ci .
# Run:   docker run --rm -v $PWD:/work -w /work cwyd-ci

FROM mcr.microsoft.com/azure-cli:latest AS azcli

FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates git unzip gnupg lsb-release jq \
    && rm -rf /var/lib/apt/lists/*

# Node 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Azure CLI (copied from official image) + bicep
COPY --from=azcli /usr/local /usr/local
COPY --from=azcli /opt /opt
RUN az bicep install || true

# azd
RUN curl -fsSL https://aka.ms/install-azd.sh | bash

# tflint (terraform optional but useful for cross-IaC checks)
RUN curl -fsSL https://raw.githubusercontent.com/terraform-linters/tflint/master/install_linux.sh | bash

# Python tooling
RUN pip install --no-cache-dir uv pre-commit

WORKDIR /work

COPY v2/docker/ci-entrypoint.sh /usr/local/bin/ci-entrypoint
RUN chmod +x /usr/local/bin/ci-entrypoint

ENTRYPOINT ["/usr/local/bin/ci-entrypoint"]
