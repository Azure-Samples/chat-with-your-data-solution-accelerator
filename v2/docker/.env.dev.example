# CWYD v2 local dev environment template.
# Copy to .env.dev (gitignored) and fill in values for any external services you want to hit.
# Local docker-compose.dev.yml overrides DB and storage to point at azurite + postgres containers.

# --- Azure AI / Foundry IQ (required for real LLM calls; mocked otherwise) ---
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=gpt-4.1
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure AI Search (optional locally) ---
AZURE_SEARCH_SERVICE=
AZURE_SEARCH_INDEX=cwyd-index

# --- Identity (optional locally; uses AzureCliCredential when unset) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# --- App ---
ORCHESTRATOR=langgraph
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:5173

# --- Frontend (consumed by the frontend container) ---
VITE_BACKEND_URL=http://localhost:8000
