# CWYD v2 root .gitignore (CU-008a, 2026-05-05).
# v2/-scoped patterns only; the repo root .gitignore covers v1 + global tooling.

# Local env (sensitive; copy from .env.sample)
.env
.env.local

# Azure Functions local host config (sensitive: storage account, endpoints, deployment names)
src/functions/local.settings.json

# Local-only scratch / throw-away diagnostics (env dumps, repro scripts)
.scratch/

# Local-only Bicep compile/lint output captured for triage (regenerated on demand via `az bicep build`).
bicep-errors.txt

# Pre-compiled ARM output. azd compiles infra/main.bicep directly (azure.yaml
# provider: bicep, module: main), so this artifact is never consumed and drifts
# from source. Regenerate on demand via `az bicep build --file infra/main.bicep`.
infra/main.json

# Local-only docker compose overrides (e.g. host ~/.azure mount for AzureCliCredential)
docker/docker-compose.override.yml

# Python build / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs (uv default + common alternates)
.venv/
venv/

# Frontend build artifacts (regenerated by `tsc -b` / `vite build`)
*.tsbuildinfo
